# Local .terraform directory (provider binaries, modules cache)
.terraform/

# Terraform state files — NEVER commit to version control
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform plan output files
*.tfplan

# Terraform variable files that may contain secrets
*.auto.tfvars
*.auto.tfvars.json

# Override files (local developer overrides, not for sharing)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lock file is safe to commit (pins provider versions)
# .terraform.lock.hcl  ← keep this in VCS

# Crash logs
crash.log
crash.*.log

# Environment variable files
.env
.env.*
